{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Product or service name"
    },
    "description": {
      "type": "string",
      "description": "Detailed description"
    },
    "category": {
      "type": "string",
      "enum": [
        "technology",
        "retail",
        "food_beverage",
        "health_wellness",
        "education",
        "professional_services",
        "real_estate",
        "automotive",
        "fashion",
        "home_garden",
        "entertainment",
        "sports_fitness",
        "beauty",
        "finance",
        "other"
      ],
      "description": "Product category"
    },
    "price": {
      "type": "number",
      "description": "Price in local currency"
    },
    "pricing_type": {
      "type": "string",
      "enum": [
        "fixed",
        "hourly",
        "monthly",
        "negotiable",
        "free"
      ],
      "default": "fixed"
    },
    "banner_image": {
      "type": "string",
      "description": "Banner/cover image URL for promotional display"
    },
    "image_url": {
      "type": "string",
      "description": "Product image URL"
    },
    "additional_images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Additional product images"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Key features or highlights"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "draft"
      ],
      "default": "active"
    },
    "location": {
      "type": "string",
      "description": "Business location"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Search tags"
    },
    "views": {
      "type": "number",
      "default": 0
    },
    "leads_generated": {
      "type": "number",
      "default": 0
    },
    "website_url": {
      "type": "string",
      "description": "External website link for this product"
    }
  },
  "required": [
    "name",
    "description",
    "category",
    "price"
  ]
}